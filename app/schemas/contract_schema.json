{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContractExtraction",
  "type": "object",
  "required": ["contract_id", "parties", "effective_date", "expiration_date"],
  "properties": {
    "contract_id": { "type": "string" },
    "contract_type": { "type": "string", "enum": ["MSA", "SOW", "NDA", "Amendment", "PO", "Other"] },
    "parties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string", "enum": ["buyer", "seller", "vendor", "licensor", "licensee", "other"] },
          "address": { "type": "string" }
        }
      }
    },
    "effective_date": { "type": ["string", "null"], "format": "date" },
    "expiration_date": { "type": ["string", "null"], "format": "date" },
    "auto_renewal": { "type": "boolean" },
    "renewal_notice_days": { "type": ["integer", "null"] },
    "total_value": { "type": ["number", "null"] },
    "currency": { "type": ["string", "null"] },
    "payment_terms": { "type": ["string", "null"] },
    "governing_law": { "type": ["string", "null"] },
    "termination_for_convenience": { "type": "boolean" },
    "liability_cap": { "type": ["number", "null"] },
    "key_obligations": { "type": "array", "items": { "type": "string" } },
    "sla_terms": { "type": "array", "items": { "type": "string" } },
    "amendments": { "type": "array", "items": { "type": "string" } },
    "confidence_scores": { "type": "object" }
  }
}
